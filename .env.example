# ── Icelandic Tutor — Environment Configuration ──────────────────────────────

# LLM Backend
# Set to "ollama" when your DGX Sparks are running Ollama
# Set to "anthropic" to use Claude API as a fallback during development
LLM_PROVIDER=anthropic

# Ollama (DGX Sparks)
# Run Ollama on one or both DGX Sparks and point this at it
# e.g. http://192.168.1.50:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:72b

OTEL_COLLECTOR_URL=http://10.10.10.1:4318

# Anthropic fallback
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Whisper STT
# Options: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda       # cuda | cpu
WHISPER_COMPUTE=float16   # float16 | int8

# TTS Voice
# Piper Icelandic voice model name
TTS_VOICE=is_IS-bui-medium
